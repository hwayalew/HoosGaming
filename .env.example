# =============================================================================
# Hoos Gaming — Environment Variables
# =============================================================================
# LOCAL DEVELOPMENT SETUP:
#   1. Copy:   cp .env.example .env.local
#   2. Fill in your real values below
#   3. Run:    npm install && npm run dev
#
# .env.local is read automatically by Next.js. Never commit it to git.
# On Replit: add keys via the Secrets panel (padlock icon in sidebar).
# =============================================================================

# ─── IBM watsonx Orchestrate — REQUIRED ───────────────────────────────────────
# HOW TO GET:
#   1. Visit https://cloud.ibm.com → Catalog → AI/Machine Learning → watsonx Orchestrate
#   2. Create or open your instance (Plus/Enterprise tier for multi-agent)
#   3. Go to: Manage → Service credentials → New credential → Role: Manager
#   4. Expand the credential and copy the "apikey" value
#
# This key is used SERVER-SIDE ONLY via /api/chat and /api/agents.
# It is exchanged for a short-lived IAM Bearer token — never sent to the browser.

WXO_MANAGER_API_KEY=your_ibm_watsonx_orchestrate_manager_api_key_here

# Secondary/native API key from the WxO instance console (optional backup)
WXO_API_KEY=your_ibm_watsonx_orchestrate_native_api_key_here

# ─── ElevenLabs — OPTIONAL ────────────────────────────────────────────────────
# Used for AI voice narration in generated games (future feature).
# Get from: https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# =============================================================================
# IBM INSTANCE INFO (update src/app/api/chat/route.ts if using your own)
# =============================================================================
# Current Instance ID : c8a9d776-460e-4c9a-b55f-0a2556febf8e
# Region              : us-south
# API Base URL        : https://api.us-south.watson-orchestrate.cloud.ibm.com/instances/<ID>
# IAM Token URL       : https://iam.cloud.ibm.com/identity/token
#
# To point to your own IBM instance:
#   Edit the BASE_URL constant in:
#     src/app/api/chat/route.ts
#     src/app/api/agents/route.ts
# =============================================================================
