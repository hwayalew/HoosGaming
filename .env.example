# =============================================================================
#  HOOS GAMING — Environment Variables
#  University of Virginia · IBM TechXchange 2025 Hackathon
# =============================================================================
#
#  LOCAL DEVELOPMENT:
#    1. cp .env.example .env.local
#    2. npm install
#    3. npm run dev          → http://localhost:3000
#
#  ⚠  IMPORTANT: .env.local is NEVER committed to git (it is in .gitignore).
#     This file (.env.example) is safe to commit — it documents every variable.
#
#  ON REPLIT: All secrets are already configured via the Secrets panel.
#             You do not need this file on Replit.
# =============================================================================


# ─────────────────────────────────────────────────────────────────────────────
#  IBM watsonx Orchestrate — REQUIRED (core AI engine)
#  78 specialized agents generate complete playable games through this API.
#
#  HOW TO GET:
#    1. https://cloud.ibm.com → Catalog → AI/Machine Learning → watsonx Orchestrate
#    2. Create or open your instance (Plus or Enterprise tier)
#    3. Manage → Service credentials → New credential → Role: Manager
#    4. Expand credential → copy the "apikey" field
#
#  Used SERVER-SIDE ONLY. Never exposed to the browser.
#  IAM Bearer token is exchanged and cached for 55 minutes.
# ─────────────────────────────────────────────────────────────────────────────

WXO_MANAGER_API_KEY=your_ibm_watsonx_orchestrate_manager_api_key_here

# Secondary native WxO console API key (optional backup auth)
WXO_API_KEY=your_ibm_watsonx_orchestrate_native_api_key_here


# ─────────────────────────────────────────────────────────────────────────────
#  Auth0 — User Authentication
#
#  PRIMARY: Auth0 React SDK (@auth0/auth0-react) — SPA, client-side only.
#    1. Create Application → Single Page Application
#    2. Settings → Allowed Callback URLs MUST include (exact match, no trailing slash):
#         http://localhost:3000
#         (add production URL when deployed)
#    3. Allowed Logout URLs: http://localhost:3000
#    4. Allowed Web Origins: http://localhost:3000
#
#  OPTIONAL (legacy): @auth0/nextjs-auth0 server routes — separate app type + secrets.
# ─────────────────────────────────────────────────────────────────────────────

# Public (safe in browser) — required for Login / Sign up buttons
NEXT_PUBLIC_AUTH0_DOMAIN=your-tenant.us.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=your_client_id_here
# Optional: override callback redirect (defaults to NEXT_PUBLIC_APP_URL without trailing /)
# NEXT_PUBLIC_AUTH0_REDIRECT_URI=http://localhost:3000

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_AUTH0_BASE_URL=http://localhost:3000

# Legacy server-side Auth0 (only if you use Next.js SDK routes)
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_auth0_client_id_here
AUTH0_CLIENT_SECRET=your_auth0_client_secret_here
AUTH0_SECRET=your_auth0_cookie_secret_here
APP_BASE_URL=http://localhost:3000
AUTH0_BASE_URL=http://localhost:3000


# ─────────────────────────────────────────────────────────────────────────────
#  FEATURE #8 — Wolfram Procedural Game Intelligence
#
#  Wolfram|Alpha API computes real-world physics constants from the game's
#  setting (e.g. moon gravity = 1.62 m/s², Mars = 3.71 m/s², water drag = 0.405)
#  and injects them directly into the AI generation prompt.
#
#  Wolfram cellular automata (Rule 30, 90, 110, 150) generate procedural
#  platform layout seeds for every level — no API key required for automaton.
#
#  HOW TO GET YOUR APP ID:
#    1. https://developer.wolframalpha.com/
#    2. Sign in → My Apps → Get an AppID
#    3. App Name: "Hoos Gaming"
#       Description: "AI game builder that uses physics constants for game generation"
#    4. Select: Full Results API
#    5. Copy the App ID (format: XXXXXX-XXXXXXXXXX)
#    Free tier: 2,000 API calls/month
#
#  Setting → Wolfram query triggered by:
#    moon → gravity 1.62 m/s² (Rule 30)   |   mars → 3.71 m/s² (Rule 90)
#    underwater → drag 0.405 (Rule 110)    |   jupiter → 24.79 m/s² (Rule 150)
#
#  Used in: /api/wolfram, /api/wolfram/automaton (server-side only)
# ─────────────────────────────────────────────────────────────────────────────

WOLFRAM_APP_ID=your_wolfram_app_id_here


# ─────────────────────────────────────────────────────────────────────────────
#  FEATURE #7 — Snowflake Game Analytics Engine
#
#  Every game generation is logged to Snowflake. Powers the /analytics page:
#    - Live "Games Built Today" counter
#    - Trending genre bar chart (last 24 hours)
#    - Average build time per engine
#    - "Building Right Now" live ticker
#    - Wolfram facts used counter
#
#  HOW TO SET UP:
#    1. https://signup.snowflake.com/ (free 30-day trial, no credit card)
#    2. Choose: AWS → US East (us-east-1)
#    3. After signup your account appears in the URL:
#       https://app.snowflake.com/us-east-1/itc52058/ → account = itc52058.us-east-1
#    4. Run these SQL commands in a Snowflake Worksheet:
#
#       CREATE DATABASE HOOS_GAMING;
#       USE DATABASE HOOS_GAMING;
#       CREATE SCHEMA ANALYTICS;
#
#       CREATE TABLE ANALYTICS.game_generations (
#         id          VARCHAR PRIMARY KEY,
#         prompt      VARCHAR,
#         engine      VARCHAR,
#         duration_ms NUMBER,
#         char_count  NUMBER,
#         pass_count  NUMBER,
#         success     BOOLEAN,
#         wolfram     BOOLEAN DEFAULT FALSE,
#         ts          TIMESTAMP_LTZ DEFAULT CURRENT_TIMESTAMP()
#       );
#
#       CREATE TABLE ANALYTICS.play_sessions (
#         id          VARCHAR PRIMARY KEY,
#         game_id     VARCHAR,
#         engine      VARCHAR,
#         duration_ms NUMBER,
#         reached_win BOOLEAN,
#         ts          TIMESTAMP_LTZ DEFAULT CURRENT_TIMESTAMP()
#       );
#
#       CREATE TABLE ANALYTICS.modifications (
#         id           VARCHAR PRIMARY KEY,
#         game_id      VARCHAR,
#         modification VARCHAR,
#         ts           TIMESTAMP_LTZ DEFAULT CURRENT_TIMESTAMP()
#       );
#
#  Used in: /api/analytics/ingest, /api/analytics/query, /api/analytics/suggestions
#  Falls back to demo data automatically if Snowflake is unreachable.
# ─────────────────────────────────────────────────────────────────────────────

SNOWFLAKE_ACCOUNT=your_snowflake_account_here
SNOWFLAKE_USER=your_snowflake_user_here
SNOWFLAKE_PASSWORD=your_snowflake_password_here
SNOWFLAKE_DATABASE=HOOS_GAMING
SNOWFLAKE_SCHEMA=ANALYTICS
SNOWFLAKE_WAREHOUSE=COMPUTE_WH


# ─────────────────────────────────────────────────────────────────────────────
#  FEATURE #6 — Presage Prediction Markets
#
#  Players open on-chain prediction markets before playing a game:
#    "Will I beat the boss?", "Will I score over 500?", "Survive 2 minutes?"
#  The market resolves automatically when the game ends (win/lose).
#  All markets run on Solana Devnet.
#
#  HOW TO GET:
#    1. https://presageprotocol.com → Sign up for developer access
#    2. Request API key (email dev@presageprotocol.com — mention IBM TechXchange)
#    Falls back to mock/demo mode if API key is not set or API is unavailable.
#
#  Used in: /api/presage/resolve (server-side only)
# ─────────────────────────────────────────────────────────────────────────────

PRESAGE_API_KEY=your_presage_api_key_here


# ─────────────────────────────────────────────────────────────────────────────
#  FEATURE #5 — Solana NFT Game Marketplace
#
#  Every generated game can be minted as a compressed NFT on Solana Devnet.
#  Game HTML is uploaded to IPFS (NFT.Storage) and linked on-chain via
#  Metaplex Bubblegum. Browse all minted games at /marketplace.
#
#  HOW TO GET SOLANA RPC URL:
#    Option A — Free public Devnet (rate-limited):
#      https://api.devnet.solana.com
#    Option B — Helius (recommended, generous free tier):
#      https://www.helius.dev/ → Dashboard → Create API Key → Devnet
#
#  HOW TO GET NFT.STORAGE API KEY:
#    1. https://nft.storage/ → Sign in
#    2. API Keys → New Key → Name: "Hoos Gaming"
#    Free tier: unlimited storage for NFT data
#
#  HOW TO GET SOLANA WALLET PRIVATE KEY:
#    Run on your Mac and paste the output below:
#      cat ~/hoos-wallet.json | python3 -c \
#        "import json,sys,base64; data=json.load(sys.stdin); \
#         print(base64.b64encode(bytes(data)).decode())"
#
#  ⚠  Use ONLY a Devnet wallet. NEVER use a mainnet wallet private key in env vars.
#  Used in: /api/mint, /marketplace page
# ─────────────────────────────────────────────────────────────────────────────

NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_WALLET_PUBKEY=your_devnet_public_wallet_key_here
SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=your_helius_api_key_here
NFT_STORAGE_API_KEY=your_nft_storage_api_key_here
SOLANA_WALLET_PRIVATE_KEY=your_base64_encoded_devnet_wallet_private_key_here


# ─────────────────────────────────────────────────────────────────────────────
#  Google Gemini — AI Game Generation Fallback
#  When IBM watsonx Orchestrate is unavailable, Hoos Gaming automatically
#  falls back to Google Gemini 1.5 Flash to generate the game.
#
#  Fallback chain: IBM watsonx Orchestrate → Gemini 1.5 Flash → Built-in demo
#
#  HOW TO GET:
#    1. https://aistudio.google.com/app/apikey
#    2. Sign in with your Google account
#    3. Click "Create API key" → Copy the key
#    Free tier: 15 req/min, 1 million tokens/min, 1,500 req/day
#
#  Used in: /api/chat (fallback), /api/gemini (direct endpoint)
# ─────────────────────────────────────────────────────────────────────────────

GEMINI_API_KEY=your_gemini_api_key_here


# ─────────────────────────────────────────────────────────────────────────────
#  ElevenLabs — AI Voice (Optional, future feature)
#  HOW TO GET: https://elevenlabs.io → Profile → API Key
# ─────────────────────────────────────────────────────────────────────────────

ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

