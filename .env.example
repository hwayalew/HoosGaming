# =============================================================================
# Hoos Gaming — Environment Variables
# =============================================================================
# LOCAL DEVELOPMENT SETUP:
#   1. Copy:   cp .env.example .env.local
#   2. Fill in your real values below
#   3. Run:    npm install && npm run dev
#
# .env.local is read automatically by Next.js. Never commit it to git.
# On Replit: add keys via the Secrets panel (padlock icon in sidebar).
# =============================================================================


# ─── IBM watsonx Orchestrate — REQUIRED ───────────────────────────────────────
# The core AI engine. 78 agents generate games through this API.
#
# HOW TO GET:
#   1. Go to https://cloud.ibm.com → Catalog → AI/Machine Learning → watsonx Orchestrate
#   2. Create or open your instance (Plus or Enterprise tier)
#   3. Go to: Manage → Service credentials → New credential → Role: Manager
#   4. Expand the credential → copy the "apikey" field
#
# Used SERVER-SIDE ONLY in /api/chat and /api/agents.
# Never exposed to the browser — exchanged for a short-lived IAM Bearer token.

WXO_MANAGER_API_KEY=your_ibm_watsonx_orchestrate_manager_api_key_here

# Secondary/native WxO console API key (optional backup auth)
WXO_API_KEY=your_ibm_watsonx_orchestrate_native_api_key_here


# ─── ElevenLabs — OPTIONAL ────────────────────────────────────────────────────
# AI voice narration for generated games.
# HOW TO GET: https://elevenlabs.io → Profile → API Key

ELEVENLABS_API_KEY=your_elevenlabs_api_key_here


# =============================================================================
# FEATURE #8 — Wolfram Procedural Game Intelligence
# =============================================================================
# Wolfram|Alpha computes real-world physics constants (moon gravity, water drag,
# etc.) that are injected into game generation. Wolfram cellular automata
# (Rule 30, 90, 110, 150) generate procedural level layout seeds.
#
# HOW TO GET YOUR APP ID:
#   1. Go to: https://developer.wolframalpha.com/
#   2. Sign in or create a free Wolfram ID account
#   3. Click "My Apps" → "Get an AppID"
#   4. App Name: "Hoos Gaming"  |  App Description: "AI game builder"
#   5. Select: "Full Results API" (not Simple or Short Answers)
#   6. Copy the App ID (format: XXXXXX-XXXXXXXXXX)
#
# Free tier: 2,000 API calls/month — sufficient for hackathon use
# Used in: /api/wolfram (server-side only)

WOLFRAM_APP_ID=your_wolfram_alpha_app_id_here


# =============================================================================
# FEATURE #7 — Snowflake Game Intelligence Engine
# =============================================================================
# Every game generation event is logged to Snowflake for analytics:
# - Live "Games Built Today" counter on /analytics
# - Trending genre charts (last 24 hours)
# - Prompt Optimizer: top-performing prompt patterns surfaced as suggestions
# - "Building Right Now" live ticker (recent anonymized prompts)
#
# HOW TO GET SNOWFLAKE CREDENTIALS:
#   1. Go to: https://signup.snowflake.com/
#   2. Sign up for a free 30-day trial (no credit card for trial)
#   3. Choose: AWS → US East (us-east-1) or US West (us-west-2)
#   4. After signup, your account identifier appears in the URL:
#      e.g. https://app.snowflake.com/us-east-1/ab12345/  → account = ab12345.us-east-1
#   5. Your USERNAME is the email/login you used to sign up
#   6. Your PASSWORD is the password you set at signup
#   7. The default WAREHOUSE is called "COMPUTE_WH"
#
#   Then run these SQL commands in your Snowflake worksheet:
#   ┌────────────────────────────────────────────────────────────┐
#   │  CREATE DATABASE HOOS_GAMING;                              │
#   │  USE DATABASE HOOS_GAMING;                                 │
#   │  CREATE SCHEMA ANALYTICS;                                  │
#   │                                                            │
#   │  CREATE TABLE game_generations (                           │
#   │    id          VARCHAR PRIMARY KEY,                        │
#   │    prompt      VARCHAR,                                    │
#   │    engine      VARCHAR,                                    │
#   │    duration_ms NUMBER,                                     │
#   │    char_count  NUMBER,                                     │
#   │    pass_count  NUMBER,                                     │
#   │    success     BOOLEAN,                                    │
#   │    wolfram     BOOLEAN DEFAULT FALSE,                      │
#   │    ts          TIMESTAMP_LTZ DEFAULT CURRENT_TIMESTAMP()   │
#   │  );                                                        │
#   │                                                            │
#   │  CREATE TABLE play_sessions (                              │
#   │    id          VARCHAR PRIMARY KEY,                        │
#   │    game_id     VARCHAR,                                    │
#   │    engine      VARCHAR,                                    │
#   │    duration_ms NUMBER,                                     │
#   │    reached_win BOOLEAN,                                    │
#   │    ts          TIMESTAMP_LTZ DEFAULT CURRENT_TIMESTAMP()   │
#   │  );                                                        │
#   │                                                            │
#   │  CREATE TABLE modifications (                              │
#   │    id               VARCHAR PRIMARY KEY,                   │
#   │    game_id          VARCHAR,                               │
#   │    modification     VARCHAR,                               │
#   │    ts               TIMESTAMP_LTZ DEFAULT CURRENT_TIMESTAMP()│
#   │  );                                                        │
#   └────────────────────────────────────────────────────────────┘
#
# SNOWFLAKE_ACCOUNT format: accountlocator.region  (e.g. ab12345.us-east-1)
# Used in: /api/analytics/ingest, /api/analytics/query, /api/analytics/suggestions

SNOWFLAKE_ACCOUNT=your_account_locator.your_region
SNOWFLAKE_USER=your_snowflake_username
SNOWFLAKE_PASSWORD=your_snowflake_password
SNOWFLAKE_DATABASE=HOOS_GAMING
SNOWFLAKE_SCHEMA=ANALYTICS
SNOWFLAKE_WAREHOUSE=COMPUTE_WH


# =============================================================================
# FEATURE #6 — Presage Score Oracle & Prediction Markets
# =============================================================================
# Lets players open on-chain prediction markets before playing a game:
# "Will I beat the boss?", "Will I score over 500?"
# Other players bet SOL; the outcome resolves automatically when the game ends.
# All markets run on Solana Devnet.
#
# HOW TO GET PRESAGE API KEY:
#   1. Go to: https://presageprotocol.com
#   2. Sign up for developer access and request an API key
#   3. Copy the API key provided
#   (Presage is an early-stage protocol — if API access requires approval,
#    email their team at dev@presageprotocol.com citing the IBM TechXchange hackathon)
#
# HOW TO GET SOLANA RPC URL (needed for both #6 and #5):
#   Option A — Free public Devnet (no signup, rate-limited):
#     https://api.devnet.solana.com
#   Option B — Helius (recommended, generous free tier):
#     1. Go to: https://www.helius.dev/
#     2. Sign up → Dashboard → Create API Key → select Devnet
#     3. Copy your RPC URL (format: https://devnet.helius-rpc.com/?api-key=XXXX)
#   Option C — QuickNode:
#     1. Go to: https://www.quicknode.com/
#     2. Create endpoint → Solana → Devnet → Copy HTTP Provider URL
#
# HOW TO GET A SOLANA HOT WALLET FOR SERVER-SIDE SIGNING:
#   1. Install Solana CLI: https://docs.solana.com/cli/install-solana-cli-tools
#   2. Run: solana-keygen new --outfile ~/.config/solana/hoos-wallet.json
#   3. Run: solana airdrop 2 --url devnet   (get free Devnet SOL)
#   4. The private key is the JSON array in hoos-wallet.json
#      Format it as a Base58 string:
#      Run: node -e "const k=require('./hoos-wallet.json'); const {Keypair}=require('@solana/web3.js'); console.log(Buffer.from(Keypair.fromSecretKey(Uint8Array.from(k)).secretKey).toString('base64'))"
#   5. Paste the Base64 output as SOLANA_WALLET_PRIVATE_KEY
#
# WARNING: Use ONLY a Devnet wallet here — never put a mainnet wallet private key in env vars.
# Used in: /api/presage (server-side only)

PRESAGE_API_KEY=your_presage_protocol_api_key_here
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WALLET_PRIVATE_KEY=your_devnet_wallet_private_key_base64_here


# =============================================================================
# FEATURE #5 — Solana Game NFT Marketplace
# =============================================================================
# Every generated game can be minted as a compressed NFT on Solana Devnet.
# Game code is uploaded to IPFS; on-chain metadata links to it permanently.
# Other players can browse and play minted games from the /marketplace page.
#
# HOW TO GET NFT.STORAGE API KEY (for IPFS upload):
#   1. Go to: https://nft.storage/
#   2. Sign in with GitHub or email
#   3. Go to: API Keys → New Key → Name: "Hoos Gaming"
#   4. Copy the API key
#   Free tier: unlimited storage for NFT data
#
#   ALTERNATIVE — Pinata (also free):
#   1. Go to: https://pinata.cloud/
#   2. Sign up → API Keys → New Key → select "pinFileToIPFS" permission
#   3. Copy the API Key AND the Secret API Key
#   Use PINATA_API_KEY + PINATA_SECRET_KEY instead of NFT_STORAGE_API_KEY
#
# SOLANA_RPC_URL — same key as Feature #6 above (already defined)
# SOLANA_WALLET_PRIVATE_KEY — same key as Feature #6 (used to pay mint fees)
#
# HOW TO GET A METAPLEX TREE ADDRESS (for compressed NFTs / Bubblegum):
#   Compressed NFTs require an on-chain Merkle tree account.
#   1. After setting up Solana CLI and funding your wallet with Devnet SOL:
#   2. Install: npm install -g @metaplex-foundation/mpl-bubblegum
#   3. Run the tree creation script (we'll provide this after setup)
#   4. Copy the tree address returned (a base58 public key)
#   (We will generate this automatically on first use if not provided)
#
# Used in: /api/mint, /marketplace page

NFT_STORAGE_API_KEY=your_nft_storage_api_key_here
# PINATA_API_KEY=your_pinata_api_key_here         # Alternative to NFT.Storage
# PINATA_SECRET_KEY=your_pinata_secret_key_here   # Alternative to NFT.Storage
METAPLEX_TREE_ADDRESS=your_merkle_tree_address_here_or_leave_blank_for_auto


