# =============================================================================
# Hoos Gaming — local secrets (DO NOT commit .env.local)
# =============================================================================
# Copy this file to `.env.local` and fill in your values.
# Restart `npm run dev` after any change. See docs/API_KEYS.md.
# =============================================================================

# --- IBM watsonx Orchestrate embed config ---
# These are NEXT_PUBLIC_* so the embed widget can load in the browser.
NEXT_PUBLIC_WXO_HOST_URL= https://us-south.watson-orchestrate.cloud.ibm.com
NEXT_PUBLIC_WXO_ORCHESTRATION_ID=
NEXT_PUBLIC_WXO_AGENT_ID=
NEXT_PUBLIC_WXO_CRN=
NEXT_PUBLIC_WXO_DEPLOYMENT_PLATFORM= ibmcloud

# Optional: override the div id the widget mounts into (default: wxochat-root)
# NEXT_PUBLIC_WXO_ROOT_ELEMENT_ID=wxochat-root

# Server-only: IBM API key for IAM token exchange
# The embed widget fires authTokenNeeded → our /api/wxo-token route
# exchanges this key for a short-lived IAM token (key never sent to browser).
WXO_API_KEY=
